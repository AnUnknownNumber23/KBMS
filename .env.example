# LLM Configuration（DeepSeek / OpenAI 均可，API 格式兼容）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Embedding: "openai" | "local"（本地 sentence-transformers，无需额外服务）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Vector Store: chroma | pgvector
VECTOR_STORE_TYPE=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# PGVector (if VECTOR_STORE_TYPE=pgvector)
PGVECTOR_DSN=postgresql://postgres:postgres@localhost:5432/knowledge

# Kafka (CDC)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# API
API_HOST=0.0.0.0
API_PORT=8080
